# Cloud Run / GCP — GitHub Variables and Secrets required for deploy.yml
# Set Variables at: GitHub repo → Settings → Secrets and variables → Actions → Variables
# Set Secrets at: GitHub repo → Settings → Secrets and variables → Actions → Secrets

# ── GitHub Variables (vars.*) ────────────────────────────────────────────────

# GCP numeric project number (found in GCP Console → Dashboard)
GCP_PROJECT_NUMBER=123456789012

# GCP text project ID (found in GCP Console → project selector)
GCP_PROJECT_ID=my-gcp-project

# Your site's domain (no https://)
APP_DOMAIN=myblog.com

# GCS bucket names (must be globally unique — recommend: {project-id}-media)
GCS_MEDIA_BUCKET=my-gcp-project-media
GCS_DIGITAL_BUCKET=my-gcp-project-digital

# Secret Manager secret ID for the Settings Encryption Key (default: aecms-sek)
SETTINGS_KMS_SECRET_ID=aecms-sek

# ── GitHub Secrets (secrets.*) ───────────────────────────────────────────────

# GCP service account JSON key with these roles:
#   Cloud Run Admin, Artifact Registry Writer, Cloud SQL Client,
#   Secret Manager Secret Accessor, Storage Admin
GCP_SA_KEY={"type":"service_account",...}

# ── GCP Secret Manager secrets (created once, referenced by deploy.yml) ─────

# aecms-database-url  → postgresql://aecms:PASSWORD@/aecms?host=/cloudsql/PROJECT:REGION:aecms-db
# aecms-jwt-secret    → output of: openssl rand -hex 64
# aecms-redis-url     → redis://default:PASSWORD@upstash-endpoint:6379
# aecms-sek           → output of: openssl rand -hex 32  (the Settings Encryption Key)
