# Dependencies
node_modules/
backend/node_modules/
frontend/node_modules/

# Build outputs
backend/dist/
frontend/.next/
frontend/out/

# Environment variables
.env
.env.local
.env.*.local
backend/.env
frontend/.env

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Testing
coverage/
.nyc_output/

# Misc
.cache/
.temp/
.tmp/

# Uploads (development only — user-uploaded files are not tracked)
# wp-import/ is the exception: those images are committed as seed assets
backend/uploads/*
!backend/uploads/wp-import
/uploads/

# Docker volumes (persistent data handled by Docker)
postgres_data/
redis_data/

# Prisma
backend/prisma/migrations/*.sql
!backend/prisma/migrations/migration_lock.toml
*.tar
*.tar.gz

# WordPress migration (contains sensitive data)
migration/

# WordPress import source files — no longer needed; images committed directly
# seed_data/ can be deleted once backend/uploads/wp-import/ is committed

# Test artifacts
test-results/
frontend/test-results/
**/playwright-report/
