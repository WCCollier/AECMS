# Railway environment variables for AECMS backend service
# Set these in Railway → Project → Service → Variables
# DATABASE_URL and REDIS_URL are provided automatically by Railway plugins

NODE_ENV=production

# ── Site URL ────────────────────────────────────────────────────────────────
# Set to your custom domain once mapped, or your Railway .up.railway.app URL
APP_URL=https://YOUR_APP.up.railway.app
FRONTEND_URL=https://YOUR_APP.up.railway.app
API_URL=https://YOUR_APP.up.railway.app
FRONTEND_ADMIN_URL=https://YOUR_APP.up.railway.app/admin

# ── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=YOUR_LONG_RANDOM_STRING
JWT_EXPIRATION=15m
REFRESH_TOKEN_EXPIRATION=7d

# ── ISM Encryption ───────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32  — keep this safe, losing it = lose all secrets
SETTINGS_KMS_PROVIDER=local
SETTINGS_ENCRYPTION_KEY=YOUR_32_BYTE_HEX_KEY

# ── Storage ──────────────────────────────────────────────────────────────────
# Option A: Local filesystem (simplest — files stored on Railway volume)
STORAGE_PROVIDER_TYPE=local
STORAGE_PATH=/app/uploads

# Option B: Cloudflare R2 (recommended for cloud — 10 GB free, zero egress)
# STORAGE_PROVIDER_TYPE=s3
# S3_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
# S3_REGION=auto
# S3_BUCKET_MEDIA=YOUR_MEDIA_BUCKET
# S3_BUCKET_DIGITAL=YOUR_DIGITAL_BUCKET
# S3_ACCESS_KEY_ID=YOUR_R2_ACCESS_KEY
# S3_SECRET_ACCESS_KEY=YOUR_R2_SECRET_KEY

# ── Email ─────────────────────────────────────────────────────────────────────
# Configure SMTP credentials in Admin Settings → Email after install — no email vars required here
