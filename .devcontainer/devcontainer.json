{
  "name": "TypeScript REST CMS + Commerce Dev",
  "image": "mcr.microsoft.com/devcontainers/typescript-node:22-bookworm",  // Explicit stable base
  
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "22"
    },
    "ghcr.io/anthropics/devcontainer-features/claude-code:1.0": {},
    "ghcr.io/devcontainers/features/github-cli:1": {},
    
    // Docker-in-Docker — fixed with moby: false for trixie/bookworm compatibility
    "ghcr.io/devcontainers/features/docker-in-docker:1": {
      "moby": false,
      "version": "latest"
    }
  },

  "forwardPorts": [3000, 5432, 6379],
  "portsAttributes": {
    "3000": { "label": "App API", "onAutoForward": "notify" }
  },

  "postCreateCommand": "npm ci && echo '✅ Dev environment ready! Run npm run dev to start.'",
  "postStartCommand": "npm run dev",   // Optional: auto-start

  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "ms-vscode.vscode-typescript-next",
        "Prisma.prisma",
        "redhat.vscode-yaml",
        "anthropic.claude-code",
        "eamodio.gitlens"
      ],
      "settings": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.formatOnSave": true,
        "typescript.preferences.importModuleSpecifier": "relative",
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  },

  "remoteUser": "node",
  "mounts": [
    "source=${localEnv:HOME}/.claude,target=/home/node/.claude,type=bind,consistency=cached"
  ],
  "containerEnv": {
    "NODE_ENV": "development"
  }
}