# ============================================================================
# AECMS Production Environment Variables
# ============================================================================
# Copy this file to .env.production and fill in all values
# NEVER commit the actual .env.production file to version control
# ============================================================================

# ----------------------------------------------------------------------------
# Core Application Settings
# ----------------------------------------------------------------------------
NODE_ENV=production

# Your production domain (no trailing slash)
APP_URL=https://yourdomain.com
API_URL=https://api.yourdomain.com
FRONTEND_URL=https://yourdomain.com
FRONTEND_ADMIN_URL=https://yourdomain.com/admin

# Store name (displayed during checkout)
STORE_NAME=Your Store Name

# ----------------------------------------------------------------------------
# Database Configuration
# ----------------------------------------------------------------------------
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Use strong passwords (32+ characters, mix of letters/numbers/symbols)
DATABASE_URL=postgresql://aecms:YOUR_STRONG_PASSWORD_HERE@postgres:5432/aecms

# Database password (for docker-compose)
DB_PASSWORD=YOUR_STRONG_PASSWORD_HERE

# ----------------------------------------------------------------------------
# Redis Configuration
# ----------------------------------------------------------------------------
# Redis connection URL for caching and sessions
# For production, consider using Redis with authentication:
# redis://:PASSWORD@HOST:PORT
REDIS_URL=redis://redis:6379

# ----------------------------------------------------------------------------
# JWT Authentication
# ----------------------------------------------------------------------------
# Generate strong secrets with: openssl rand -base64 64
JWT_SECRET=GENERATE_A_STRONG_64_CHAR_SECRET_HERE
JWT_REFRESH_SECRET=GENERATE_ANOTHER_STRONG_64_CHAR_SECRET_HERE

# Token expiration times
JWT_EXPIRATION=15m
REFRESH_TOKEN_EXPIRATION=7d

# ----------------------------------------------------------------------------
# Payment Processing - Stripe (Primary)
# ----------------------------------------------------------------------------
# Get LIVE keys from: https://dashboard.stripe.com/apikeys
# IMPORTANT: Use LIVE keys, not test keys
STRIPE_SECRET_KEY=sk_live_YOUR_STRIPE_SECRET_KEY
STRIPE_PUBLISHABLE_KEY=pk_live_YOUR_STRIPE_PUBLISHABLE_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET

# ----------------------------------------------------------------------------
# Payment Processing - PayPal (Secondary)
# ----------------------------------------------------------------------------
# Get LIVE credentials from: https://developer.paypal.com/dashboard/applications/live
PAYPAL_CLIENT_ID=YOUR_PAYPAL_CLIENT_ID
PAYPAL_CLIENT_SECRET=YOUR_PAYPAL_CLIENT_SECRET
PAYPAL_MODE=live

# Disable test mode for real payments
PAYMENT_TEST_MODE=false

# ----------------------------------------------------------------------------
# AI Moderation - OpenAI
# ----------------------------------------------------------------------------
# Get API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-YOUR_OPENAI_API_KEY

# ----------------------------------------------------------------------------
# OAuth Providers (Optional)
# ----------------------------------------------------------------------------
# Google OAuth
# Get credentials from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Apple OAuth
# Get credentials from: https://developer.apple.com/account/resources/identifiers/list/serviceId
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# ----------------------------------------------------------------------------
# Email / SMTP Configuration
# ----------------------------------------------------------------------------
# Provider type: 'smtp' for production (use 'console' only for testing)
EMAIL_PROVIDER_TYPE=smtp

# SMTP Server Settings
# Compatible with: SendGrid, Mailgun, Amazon SES, Gmail, etc.
SMTP_HOST=smtp.youremailprovider.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@yourdomain.com

# Alternative: AWS SES (if using SES instead of generic SMTP)
AWS_SES_REGION=us-east-1
AWS_SES_ACCESS_KEY_ID=
AWS_SES_SECRET_ACCESS_KEY=
AWS_SES_FROM_EMAIL=noreply@yourdomain.com

# ----------------------------------------------------------------------------
# Storage Configuration
# ----------------------------------------------------------------------------
# Provider type: 'local' for filesystem storage
# Future: 's3' for AWS S3, 'gcs' for Google Cloud Storage
STORAGE_PROVIDER_TYPE=local

# Local storage path (inside container)
STORAGE_PATH=/app/uploads

# ----------------------------------------------------------------------------
# Security Settings
# ----------------------------------------------------------------------------
# CORS allowed origins (comma-separated for multiple)
CORS_ORIGINS=https://yourdomain.com

# Rate limiting (requests per minute)
RATE_LIMIT_MAX=100

# ----------------------------------------------------------------------------
# Logging
# ----------------------------------------------------------------------------
# Log level: error, warn, info, debug
LOG_LEVEL=info
