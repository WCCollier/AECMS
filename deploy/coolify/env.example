# Coolify / VPS environment variables for AECMS
# Set these in Coolify's environment variable editor, or in a .env file on your VPS

# ── Domain ───────────────────────────────────────────────────────────────────
APP_DOMAIN=yourdomain.com

# ── Database & Cache ─────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 24
POSTGRES_PASSWORD=YOUR_POSTGRES_PASSWORD
REDIS_PASSWORD=YOUR_REDIS_PASSWORD

# ── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=YOUR_LONG_RANDOM_STRING

# ── ISM Encryption ───────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32  — store this somewhere safe
SETTINGS_ENCRYPTION_KEY=YOUR_32_BYTE_HEX_KEY

# ── Storage ──────────────────────────────────────────────────────────────────
# local: files stored in uploads/ volume (simplest, included in docker-compose)
STORAGE_PROVIDER_TYPE=local

# For Cloudflare R2, Backblaze B2, etc., switch to s3 and set:
# STORAGE_PROVIDER_TYPE=s3
# (configure bucket names + credentials in Admin Settings → File Storage after install)

# ── Email ─────────────────────────────────────────────────────────────────────
# Configure SMTP credentials in Admin Settings → Email after install — no email vars required here
